NAME=FastAPI Application
DESCRIPTION=FastAPI Application
VERSION=1.0.0

HOST=127.0.0.1
PORT=8000
RELOAD=True

DATABASE_URL=sqlite+aiosqlite:///./data/database.db
DB_REQUIRE_TLS=True
# WARNING: Set to False in production. Run migrations separately via CI/CD.
RUN_MIGRATIONS_ON_STARTUP=False

LOG_LEVEL=INFO
SQLALCHEMY_LOG_LEVEL=WARNING
LOG_ENQUEUE=False
